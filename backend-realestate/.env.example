# ── Database ───────────────────────────────────────────────────────────
# Railway PostgreSQL은 "postgresql://..." 형태로 주입하므로 드라이버 prefix 자동 보정
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fomobot_re
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/fomobot_re

# ── App ────────────────────────────────────────────────────────────────
APP_ENV=development               # development | production
LOG_LEVEL=INFO

# CORS — 콤마로 구분된 허용 오리진 목록
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Sentry (비워두면 초기화 스킵) ──────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── 스케줄러 (dev 전용) ────────────────────────────────────────────────
# true: APScheduler 활성화 / false: Railway Cron이 jobs.* 를 직접 호출
ENABLE_SCHEDULER=false

# ── 국토교통부 실거래가 API ─────────────────────────────────────────────
# 공공데이터포털(data.go.kr)에서 발급한 서비스키 (URL 인코딩 전 원문)
MOLIT_API_KEY=

# ── 수집 설정 ───────────────────────────────────────────────────────────
RE_MIN_TRANSACTION_COUNT=5          # 랭킹 산정 최소 거래 건수 (미달 시 "데이터 부족")
RE_API_CALL_DELAY_SEC=0.3           # API 호출 간격 (초) — 국토부 트래픽 한도 대응
RE_BACKFILL_MAX_GU_PER_RUN=30       # 백필 1회 최대 처리 시군구 수 (30 × ~246개월 ≈ 7,380 호출)
RE_BACKFILL_START_YEAR_MONTH=200601 # 백필 시작 년월 (국토부 공개 시작: 2006년)

# ── Health check ───────────────────────────────────────────────────────
HEALTH_STALE_DAYS=40               # 마지막 수집이 이 일수 이상 지나면 503
