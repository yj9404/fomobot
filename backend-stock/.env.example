# ── Database ──────────────────────────────────────────────────────────────────
# Railway PostgreSQL 서비스가 자동으로 주입하는 경우 DATABASE_URL 단일 변수로도 가능.
# asyncpg(웹 앱용) / psycopg2(배치·Alembic용) 두 드라이버를 구분해 설정한다.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fomobot
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/fomobot

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# 콤마로 구분된 허용 오리진 목록.
# 로컬 개발 + 배포 프론트 도메인을 모두 포함할 것.
# 예: ALLOWED_ORIGINS=http://localhost:5173,https://fomobot.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Sentry ────────────────────────────────────────────────────────────────────
# 값이 비어 있으면 Sentry 초기화 스킵 (로컬 개발 시 설정 불필요).
# Sentry 프로젝트 → Settings → Client Keys 에서 DSN 확인.
SENTRY_DSN=
# 트레이싱 샘플 비율 (0.0 ~ 1.0). prod 에서는 0.05~0.1 권장.
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Scheduler ─────────────────────────────────────────────────────────────────
# true: 웹 프로세스 안에서 APScheduler 실행 (로컬 개발 전용).
# false(기본): Railway Cron 이 fomobot.jobs.collect 를 직접 호출. 웹 프로세스에서는 스케줄링 안 함.
ENABLE_SCHEDULER=false

# ── Health check ──────────────────────────────────────────────────────────────
# GET /health 에서 마지막 수집이 이 시간(시) 이상 지나면 503 unhealthy 반환.
# UptimeRobot 이 503 을 감지해 데이터 정체 알림을 보낸다.
# 평일 1회 수집 기준으로 25시간(하루 + 1시간 여유)을 권장.
HEALTH_STALE_HOURS=25

# ── KRX 인증 ──────────────────────────────────────────────────────────────────
# pykrx 가 KRX 데이터 조회 시 필요한 계정 정보.
# data.krx.co.kr 에서 무료 회원가입 후 발급.
# Railway Cron 서비스에도 동일하게 설정해야 함.
KRX_ID=
KRX_PW=

# ── Noise Filter - KOSPI ──────────────────────────────────────────────────────
KOSPI_MIN_MARKET_CAP=100000000000
KOSPI_MIN_AVG_VOLUME_30D=1000000000
KOSPI_MIN_PRICE=1000

# ── Noise Filter - NASDAQ ─────────────────────────────────────────────────────
NASDAQ_MIN_MARKET_CAP_USD=500000000
NASDAQ_MIN_AVG_VOLUME_30D_USD=5000000
NASDAQ_MIN_PRICE_USD=5.0

# ── Batch settings ────────────────────────────────────────────────────────────
BATCH_SIZE_NASDAQ=100
NASDAQ_BATCH_DELAY_SEC=2.0
NASDAQ_MAX_CONSEC_FAILURES=5
NASDAQ_CIRCUIT_BREAKER_WAIT_SEC=1800

# ── 네이버 뉴스 검색 API (관련 뉴스 링크 기능) ──────────────────────────────────
# developers.naver.com 에서 애플리케이션 등록 후 발급 (검색 API 사용 설정 필요).
# 비어 있으면 뉴스 배치가 스킵된다(에러 아님).
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# stock_news 캐시 TTL(일). 표시용 캐시일 뿐 영구 저장이 아니며, 만료분은 배치가 삭제한다.
STOCK_NEWS_TTL_DAYS=2
